{
  "name": "receiptserver",
  "version": "1.0.0",
  "description": "ScanReceipt backend dashboard",
  "scripts": {
    "dev": "concurrently \"tsx watch src/index.ts\" \"cd client && npm run dev\"",
    "build": "prisma generate && tsc -p tsconfig.json && cd client && npm run build",
    "start": "node dist/index.js",
    "start:tsx": "tsx src/index.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "concurrently": "^9.1.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
